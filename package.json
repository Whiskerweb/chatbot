{
  "name": "chatbot-saas",
  "private": true,
  "scripts": {
    "postinstall": "pnpm --filter @chatbot/db generate",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @chatbot/db generate",
    "db:push": "pnpm --filter @chatbot/db push",
    "db:migrate": "pnpm --filter @chatbot/db migrate",
    "db:studio": "pnpm --filter @chatbot/db studio",
    "db:seed": "pnpm --filter @chatbot/db seed"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "traaaction": "^1.3.0"
  }
}
